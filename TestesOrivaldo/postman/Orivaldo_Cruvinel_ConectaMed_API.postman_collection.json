        {
          "name": "CT04 - Cadastro com dados validos",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/users/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Orivaldo Cruvinel\",\n  \"email\": \"{{valid_email}}\",\n  \"password\": \"{{valid_password}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const email = `orivaldo_${Date.now()}@teste.com`;",
                  "pm.collectionVariables.set('valid_email', email);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code deve ser 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Resposta deve conter usuario criado', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('message');",
                  "  pm.expect(json).to.have.property('user');",
                  "  pm.expect(json.user).to.have.property('id');",
                  "  pm.expect(json.user.email).to.eql(pm.variables.get('valid_email'));",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
