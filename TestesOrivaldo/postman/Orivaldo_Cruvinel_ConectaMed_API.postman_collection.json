      "name": "API 1 - Cadastro de Usuario",
      "item": [
        {
          "name": "CT01 - Cadastro sem nome",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/users/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"\",\n  \"email\": \"orivaldo.sem.nome@teste.com\",\n  \"password\": \"Senha123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code deve ser 400', function () {",
                  "  pm.response.to.have.status(400);",
                  "});",
                  "pm.test('Resposta deve conter erro', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('error');",
                  "});"
                ]
              }
            }
          ]
        },
